---
import NavLink from './NavLink.astro';
import { NAV_ITEMS } from '../consts';
---

<header>
	<nav>
		<div class="nav-left">
			<a href="/" class="logo">
				<span class="logo-text">PII Anonymizer</span>
			</a>
			<div class="nav-links">
				{NAV_ITEMS.map((item) => (
					<NavLink href={item.href} label={item.label} />
				))}
			</div>
		</div>
		<div class="nav-right">
			<a href="https://huggingface.co/bardsai/eu-pii-anonimization-multilang" target="_blank" rel="noopener" title="Model on Hugging Face" class="icon-link">
				<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 120 120" aria-hidden="true">
					<path fill="currentColor" d="M60 0C26.9 0 0 26.9 0 60s26.9 60 60 60 60-26.9 60-60S93.1 0 60 0zm0 112C31.3 112 8 88.7 8 60S31.3 8 60 8s52 23.3 52 52-23.3 52-52 52z"/>
					<text x="50%" y="58%" dominant-baseline="middle" text-anchor="middle" fill="currentColor" font-size="50" font-weight="bold">HF</text>
				</svg>
			</a>
			<a href="https://github.com/bards-ai" target="_blank" rel="noopener" title="GitHub" class="icon-link">
				<svg viewBox="0 0 16 16" aria-hidden="true" width="18" height="18">
					<path fill="currentColor" d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.012 8.012 0 0 0 16 8c0-4.42-3.58-8-8-8z"/>
				</svg>
			</a>
		</div>
	</nav>
</header>

<style>
	header {
		position: sticky;
		top: 0;
		z-index: 100;
		background: var(--color-surface);
		border-bottom: 1px solid var(--color-border);
	}
	nav {
		display: flex;
		align-items: center;
		justify-content: space-between;
		max-width: 960px;
		margin: 0 auto;
		padding: 0 var(--space-md);
		height: 52px;
	}
	.nav-left {
		display: flex;
		align-items: center;
		gap: var(--space-xl);
	}
	.logo {
		display: flex;
		align-items: center;
		text-decoration: none;
	}
	.logo:hover {
		text-decoration: none;
	}
	.logo-text {
		font-weight: 700;
		font-size: 0.95rem;
		color: var(--color-text);
		letter-spacing: -0.01em;
	}
	.nav-links {
		display: flex;
		align-items: center;
		gap: var(--space-xs);
	}
	.nav-right {
		display: flex;
		align-items: center;
		gap: 2px;
	}
	.icon-link {
		display: flex;
		align-items: center;
		padding: 6px;
		color: var(--color-text-secondary);
		border-radius: var(--radius-sm);
		transition: color 0.15s;
	}
	.icon-link:hover {
		color: var(--color-text);
	}

	@media (max-width: 640px) {
		.nav-links { gap: 0; }
		.nav-left { gap: var(--space-md); }
	}
</style>
