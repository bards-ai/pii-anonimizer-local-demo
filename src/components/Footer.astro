---
const year = new Date().getFullYear();
---

<footer>
	<div class="footer-inner">
		<div class="footer-main">
			<p class="footer-brand">Built by <a href="https://bards.ai" target="_blank" rel="noopener">bards.ai</a></p>
			<p class="footer-meta">Licensed under Apache 2.0 &middot; No data leaves your browser</p>
		</div>
		<div class="footer-links">
			<a href="/docs">Docs</a>
			<a href="/about">About</a>
			<a href="https://huggingface.co/bardsai/eu-pii-anonimization-multilang" target="_blank" rel="noopener">HuggingFace</a>
			<a href="https://github.com/bards-ai" target="_blank" rel="noopener">GitHub</a>
		</div>
		<p class="footer-copy">&copy; {year} bards.ai. All rights reserved.</p>
	</div>
</footer>

<style>
	footer {
		border-top: 1px solid var(--color-border);
		padding: var(--space-2xl) var(--space-md);
		color: var(--color-text-secondary);
		font-size: 0.85rem;
	}
	.footer-inner {
		max-width: 960px;
		margin: 0 auto;
		text-align: center;
	}
	.footer-brand {
		font-weight: 600;
		color: var(--color-text);
		margin-bottom: var(--space-xs);
	}
	.footer-brand a {
		color: var(--color-primary);
	}
	.footer-meta {
		margin-bottom: var(--space-lg);
		font-size: 0.8rem;
	}
	.footer-links {
		display: flex;
		justify-content: center;
		gap: var(--space-lg);
		margin-bottom: var(--space-lg);
	}
	.footer-links a {
		color: var(--color-text-secondary);
		text-decoration: none;
	}
	.footer-links a:hover {
		color: var(--color-text);
	}
	.footer-copy {
		font-size: 0.75rem;
		margin: 0;
	}
</style>
