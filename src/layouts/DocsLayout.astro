---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import DocsSidebar from '../components/DocsSidebar.astro';

interface Props {
	title: string;
	description: string;
}

const { title, description } = Astro.props;
---

<html lang="en">
	<head>
		<BaseHead title={`${title} — PII Anonymizer`} description={description} />
	</head>
	<body>
		<Header />
		<main class="docs-main">
			<DocsSidebar />
			<article class="docs-content prose">
				<slot />
			</article>
		</main>
		<Footer />

		<style>
			.docs-main {
				display: grid;
				grid-template-columns: 200px 1fr;
				gap: var(--space-xl);
				align-items: start;
			}
			.docs-content {
				min-width: 0;
			}
			.docs-content :global(h1) {
				margin-bottom: var(--space-lg);
			}
			.docs-content :global(h2) {
				margin-top: var(--space-2xl);
				padding-top: var(--space-lg);
				border-top: 1px solid var(--color-border);
				font-size: 1.375rem;
			}
			.docs-content :global(h2:first-of-type) {
				border-top: none;
				padding-top: 0;
			}
			.docs-content :global(h3) {
				margin-top: var(--space-xl);
				font-size: 1.125rem;
			}
			.docs-content :global(table) {
				border-collapse: collapse;
				font-size: 0.875rem;
				margin-bottom: var(--space-xl);
			}
			.docs-content :global(th),
			.docs-content :global(td) {
				text-align: left;
				padding: 0.5rem 0.75rem;
				border-bottom: 1px solid var(--color-border);
			}
			.docs-content :global(th) {
				font-weight: 600;
				color: var(--color-text-secondary);
				font-size: 0.8rem;
				text-transform: uppercase;
				letter-spacing: 0.04em;
				background: var(--color-surface-alt);
			}
			.docs-content :global(code) {
				font-size: 0.85em;
			}
			.docs-content :global(pre) {
				margin-bottom: var(--space-xl);
			}

			@media (max-width: 768px) {
				.docs-main {
					grid-template-columns: 1fr;
				}
			}
		</style>
	</body>
</html>
