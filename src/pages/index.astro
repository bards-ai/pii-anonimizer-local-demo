---
import BaseHead from "../components/BaseHead.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import EntityCategoryCard from "../components/EntityCategoryCard.astro";
import { SITE_TITLE, SITE_DESCRIPTION } from "../consts";

const CATEGORIES = [
  { name: "Personal Identity", article: "GDPR Art. 4(1)", entities: ["PERSON_NAME", "DATE_OF_BIRTH", "PERSON_ATTRIBUTE", "PERSON_ALIAS", "PERSON_IDENTIFIER"] },
  { name: "Organizations", article: "GDPR Art. 4(1)", entities: ["ORGANIZATION_NAME", "ORGANIZATION_IDENTIFIER"] },
  { name: "Contact & Location", article: "GDPR Art. 4(1)", entities: ["EMAIL_ADDRESS", "PHONE_NUMBER", "CONTACT_HANDLE", "POSTAL_ADDRESS", "LOCATION", "GEO_LOCATION"] },
  { name: "Technical Identifiers", article: "GDPR Recital 30", entities: ["IP_ADDRESS", "DEVICE_IDENTIFIER", "COOKIE_IDENTIFIER", "ACCOUNT_IDENTIFIER", "AUTH_SECRET"] },
  { name: "Financial", article: "GDPR Art. 4(1)", entities: ["BANK_ACCOUNT_IDENTIFIER", "PAYMENT_CARD", "PAYMENT_CARD_SECURITY", "DOCUMENT_REFERENCE", "FINANCIAL_AMOUNT", "INCOME_COMPENSATION", "VEHICLE_IDENTIFIER"] },
  { name: "Health & Biometric", article: "GDPR Art. 9(1)", entities: ["HEALTH_DATA", "GENETIC_DATA", "BIOMETRIC_DATA"] },
  { name: "Special Categories", article: "GDPR Art. 9(1)", entities: ["RELIGION_OR_BELIEF", "POLITICAL_OPINION", "SEXUAL_ORIENTATION", "TRADE_UNION_MEMBERSHIP", "ETHNIC_ORIGIN", "CRIMINAL_OFFENCE_DATA"] },
  { name: "Employment", article: "GDPR Art. 88", entities: ["PERSON_ROLE_OR_TITLE"] },
];
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
  </head>
  <body>
    <Header />
    <main>
      <!-- Hero -->
      <section class="hero">
        <p class="hero-kicker">Open-source &middot; Apache 2.0 &middot; 35 entity types &middot; runs locally</p>
        <h1>Make your AI data processing EU&#8209;compliant</h1>
        <p class="subtitle">
          Detect and anonymize personal data before it enters your AI pipeline.
          Covers all PII defined by GDPR Art.&nbsp;4(1), special categories under Art.&nbsp;9(1),
          and meets the anonymization requirements of EU&nbsp;AI&nbsp;Act Art.&nbsp;10(5).
          Built on <a href="https://huggingface.co/bardsai/eu-pii-anonimization" target="_blank" rel="noopener">bardsai/eu-pii-anonimization</a>,
          an open-source XLM-RoBERTa token classifier running entirely in your browser via ONNX/WebAssembly &mdash; no data leaves your device.
        </p>
        <div class="language-grid">
          <span class="lang-label">EU languages:</span>
          <span class="lang-item lang-disabled">🇬🇧 English</span>
          <span class="lang-item lang-active">🇵🇱 Polish</span>
          <span class="lang-item lang-disabled">🇩🇪 German</span>
          <span class="lang-item lang-disabled">🇫🇷 French</span>
          <span class="lang-item lang-disabled">🇪🇸 Spanish</span>
          <span class="lang-item lang-disabled">🇮🇹 Italian</span>
          <span class="lang-item lang-disabled">🇳🇱 Dutch</span>
          <span class="lang-item lang-disabled">🇵🇹 Portuguese</span>
          <span class="lang-item lang-disabled">🇷🇴 Romanian</span>
          <span class="lang-item lang-disabled">🇨🇿 Czech</span>
          <span class="lang-item lang-disabled">🇸🇪 Swedish</span>
          <span class="lang-item lang-disabled">🇬🇷 Greek</span>
          <span class="lang-item lang-disabled">🇭🇺 Hungarian</span>
          <span class="lang-item lang-disabled">🇧🇬 Bulgarian</span>
          <span class="lang-item lang-disabled">🇭🇷 Croatian</span>
          <span class="lang-item lang-disabled">🇩🇰 Danish</span>
          <span class="lang-item lang-disabled">🇪🇪 Estonian</span>
          <span class="lang-item lang-disabled">🇫🇮 Finnish</span>
          <span class="lang-item lang-disabled">🇮🇪 Irish</span>
          <span class="lang-item lang-disabled">🇱🇻 Latvian</span>
          <span class="lang-item lang-disabled">🇱🇹 Lithuanian</span>
          <span class="lang-item lang-disabled">🇲🇹 Maltese</span>
          <span class="lang-item lang-disabled">🇸🇰 Slovak</span>
          <span class="lang-item lang-disabled">🇸🇮 Slovenian</span>
        </div>
      </section>

      <!-- Demo -->
      <section class="demo-section" id="demo">
        <div class="demo-card">
          <div class="controls">
            <div class="model-status" id="model-status">
              <div class="status-text" id="status-text">Click to download the model from HuggingFace</div>
              <div class="progress-bar-container" id="progress-container" style="display:none">
                <div class="progress-bar" id="progress-bar"></div>
              </div>
            </div>
            <button id="load-btn" class="btn btn-secondary">Download bardsai/eu-pii-anonimization</button>
          </div>
          <div class="mobile-warning" id="mobile-warning" style="display:none">
            The model requires ~300 MB of memory. On mobile devices this may cause the browser tab to reload. For best results, use a desktop browser.
          </div>

          <div class="input-section">
            <div class="section-header">
              <label for="input-text">Input Text</label>
              <div class="sample-buttons">
                <button class="btn btn-outline btn-small sample-btn" data-sample="1">Sample 1</button>
                <button class="btn btn-outline btn-small sample-btn" data-sample="2">Sample 2</button>
                <button class="btn btn-outline btn-small sample-btn" data-sample="3">Sample 3</button>
              </div>
            </div>
            <textarea id="input-text" rows="6" placeholder="Wpisz tekst po polsku zawierający dane osobowe...">Pracownik Anna Wiśniewska, zatrudniona w dziale IT, otrzymuje wynagrodzenie w wysokości 12 500 PLN brutto. Numer paszportu: EP1234567. NIP firmy: 527-020-1234. Adres zamieszkania: ul. Piękna 22, 00-549 Warszawa. Wyznanie: katolicyzm. Przynależność związkowa: NSZZ.</textarea>
            <button id="analyze-btn" class="btn btn-primary" disabled>Analyze</button>
          </div>

          <div class="output-section">
            <div class="output-header">
              <h3>Results <span class="preview-label" id="preview-label">preview</span></h3>
              <div class="view-toggle" id="view-toggle" style="display:flex">
                <button class="toggle-btn" data-view="anonymized">Anonymized</button>
                <button class="toggle-btn active" data-view="highlighted">Highlighted</button>
              </div>
            </div>
            <div id="output-anonymized" class="output-text" style="display:none">Pracownik <span class="anon-tag cat-identity" title="Was: Anna Wiśniewska (100%)">[PERSON_NAME]</span>, zatrudniona w dziale <span class="anon-tag cat-identity" title="Was: IT (85%)">[PERSON_ROLE_OR_TITLE]</span>, otrzymuje wynagrodzenie w wysokości <span class="anon-tag cat-financial" title="Was: 12 500 PLN brutto (91%)">[FINANCIAL_AMOUNT]</span>. Numer paszportu: <span class="anon-tag cat-identity" title="Was: EP1234567 (64%)">[ORGANIZATION_IDENTIFIER]</span>. NIP firmy: <span class="anon-tag cat-identity" title="Was: 527-020-1234 (100%)">[ORGANIZATION_IDENTIFIER]</span>. Adres zamieszkania: <span class="anon-tag cat-contact" title="Was: ul. Piękna 22, 00-549 (100%)">[POSTAL_ADDRESS]</span> <span class="anon-tag cat-contact" title="Was: Warszawa (89%)">[LOCATION]</span>. Wyznanie: <span class="anon-tag cat-special" title="Was: katolicyzm (100%)">[RELIGION_OR_BELIEF]</span>. Przynależność związkowa: <span class="anon-tag cat-special" title="Was: NSZZ (53%)">[TRADE_UNION_MEMBERSHIP]</span>.</div>
            <div id="output-highlighted" class="output-text">Pracownik <mark class="entity cat-identity" title="PERSON_NAME (100%)">Anna Wiśniewska<span class="entity-label">PERSON_NAME</span></mark>, zatrudniona w dziale <mark class="entity cat-identity" title="PERSON_ROLE_OR_TITLE (85%)">IT<span class="entity-label">PERSON_ROLE_OR_TITLE</span></mark>, otrzymuje wynagrodzenie w wysokości <mark class="entity cat-financial" title="FINANCIAL_AMOUNT (91%)">12 500 PLN brutto<span class="entity-label">FINANCIAL_AMOUNT</span></mark>. Numer paszportu: <mark class="entity cat-identity" title="ORGANIZATION_IDENTIFIER (64%)">EP1234567<span class="entity-label">ORGANIZATION_IDENTIFIER</span></mark>. NIP firmy: <mark class="entity cat-identity" title="ORGANIZATION_IDENTIFIER (100%)">527-020-1234<span class="entity-label">ORGANIZATION_IDENTIFIER</span></mark>. Adres zamieszkania: <mark class="entity cat-contact" title="POSTAL_ADDRESS (100%)">ul. Piękna 22, 00-549<span class="entity-label">POSTAL_ADDRESS</span></mark> <mark class="entity cat-contact" title="LOCATION (89%)">Warszawa<span class="entity-label">LOCATION</span></mark>. Wyznanie: <mark class="entity cat-special" title="RELIGION_OR_BELIEF (100%)">katolicyzm<span class="entity-label">RELIGION_OR_BELIEF</span></mark>. Przynależność związkowa: <mark class="entity cat-special" title="TRADE_UNION_MEMBERSHIP (53%)">NSZZ<span class="entity-label">TRADE_UNION_MEMBERSHIP</span></mark>.</div>
            <div id="entity-list" class="entity-list">
              <h4>Detected Entities</h4>
              <div id="entity-table-container"><table class="results-table"><thead><tr><th>Entity</th><th>Type</th><th>Regulation</th><th class="col-confidence">Confidence</th></tr></thead><tbody><tr><td><span class="entity-badge cat-identity">Anna Wiśniewska</span></td><td><code>PERSON_NAME</code></td><td><span class="reg-ref">Art. 4(1)</span></td><td class="col-confidence">100%</td></tr><tr><td><span class="entity-badge cat-identity">IT</span></td><td><code>PERSON_ROLE_OR_TITLE</code></td><td><span class="reg-ref">Art. 4(1)</span></td><td class="col-confidence">85%</td></tr><tr><td><span class="entity-badge cat-financial">12 500 PLN brutto</span></td><td><code>FINANCIAL_AMOUNT</code></td><td><span class="reg-ref">Art. 4(1)</span></td><td class="col-confidence">91%</td></tr><tr><td><span class="entity-badge cat-identity">EP1234567</span></td><td><code>ORGANIZATION_IDENTIFIER</code></td><td><span class="reg-ref">Art. 4(1)</span></td><td class="col-confidence">64%</td></tr><tr><td><span class="entity-badge cat-identity">527-020-1234</span></td><td><code>ORGANIZATION_IDENTIFIER</code></td><td><span class="reg-ref">Art. 4(1)</span></td><td class="col-confidence">100%</td></tr><tr><td><span class="entity-badge cat-contact">ul. Piękna 22, 00-549</span></td><td><code>POSTAL_ADDRESS</code></td><td><span class="reg-ref">Art. 4(1)</span></td><td class="col-confidence">100%</td></tr><tr><td><span class="entity-badge cat-contact">Warszawa</span></td><td><code>LOCATION</code></td><td><span class="reg-ref">Art. 4(1)</span></td><td class="col-confidence">89%</td></tr><tr><td><span class="entity-badge cat-special">katolicyzm</span></td><td><code>RELIGION_OR_BELIEF</code></td><td><span class="reg-ref reg-special">Art. 9(1)</span></td><td class="col-confidence">100%</td></tr><tr><td><span class="entity-badge cat-special">NSZZ</span></td><td><code>TRADE_UNION_MEMBERSHIP</code></td><td><span class="reg-ref reg-special">Art. 9(1)</span></td><td class="col-confidence">53%</td></tr></tbody></table></div>
            </div>
          </div>
        </div>
      </section>

      <!-- Entity Categories -->
      <section class="categories-section">
        <h2>Entity taxonomy</h2>
        <p class="section-desc">
          35 entity types across 8 categories, mapped to specific GDPR articles.
          Art.&nbsp;9(1) special categories (health, biometric, genetic, political, religious, ethnic, sexual orientation, trade union)
          are flagged separately to support higher-risk processing rules.
        </p>
        <div class="categories-grid">
          {CATEGORIES.map((cat) => (
            <EntityCategoryCard name={cat.name} entities={cat.entities} article={cat.article} />
          ))}
        </div>
        <p class="section-link">
          <a href="/docs/entity-categories">Full entity reference &rarr;</a>
        </p>
      </section>

      <!-- Regulatory context -->
      <section class="regulation-section">
        <h2>Regulatory context</h2>
        <p class="section-desc">
          This model addresses requirements from two EU regulations. Below are the specific provisions
          that PII detection and anonymisation tools help satisfy.
        </p>
        <div class="reg-grid">
          <div class="reg-block">
            <h3>GDPR <span class="reg-id">(Regulation 2016/679)</span></h3>
            <dl class="reg-list">
              <div class="reg-item">
                <dt>Art. 4(1) &mdash; Personal data</dt>
                <dd>Defines the scope: any information relating to an identified or identifiable natural person. The 35 entity types in this model map directly to the identifiers listed here.</dd>
              </div>
              <div class="reg-item">
                <dt>Art. 5(1)(c) &mdash; Data minimisation</dt>
                <dd>Personal data must be adequate, relevant, and limited to what is necessary. Automated PII detection is a technical measure to enforce minimisation at scale.</dd>
              </div>
              <div class="reg-item">
                <dt>Art. 9(1) &mdash; Special categories</dt>
                <dd>Processing of health, biometric, genetic, racial/ethnic, political, religious, trade union, and sexual orientation data is prohibited by default. This model detects all eight special categories.</dd>
              </div>
              <div class="reg-item">
                <dt>Art. 25 &mdash; Data protection by design</dt>
                <dd>Controllers must implement appropriate technical measures, such as pseudonymisation, to implement data-protection principles. PII detection is a prerequisite for pseudonymisation.</dd>
              </div>
              <div class="reg-item">
                <dt>Art. 32(1)(a) &mdash; Security of processing</dt>
                <dd>Lists pseudonymisation and encryption as appropriate security measures. Automated PII detection enables systematic pseudonymisation of personal data.</dd>
              </div>
            </dl>
          </div>
          <div class="reg-block">
            <h3>EU AI Act <span class="reg-id">(Regulation 2024/1689)</span></h3>
            <dl class="reg-list">
              <div class="reg-item">
                <dt>Art. 10(5) &mdash; Data governance for high-risk AI</dt>
                <dd>Special-category personal data may only be used for bias detection when anonymised or synthetic data cannot fulfill the purpose. Requires &ldquo;state-of-the-art pseudonymisation&rdquo; when processing is necessary.</dd>
              </div>
              <div class="reg-item">
                <dt>Art. 59 &mdash; AI regulatory sandboxes</dt>
                <dd>Personal data in sandboxes may only be processed when anonymised or synthetic data is insufficient. Establishes an anonymisation-first principle for AI development.</dd>
              </div>
              <div class="reg-item">
                <dt>Recital 69 &mdash; Privacy throughout AI lifecycle</dt>
                <dd>Data minimisation and protection by design must be ensured throughout the entire AI lifecycle. Lists anonymisation and encryption as compliance measures.</dd>
              </div>
              <div class="reg-item">
                <dt>Annex III, &sect;1 &mdash; High-risk: biometrics</dt>
                <dd>Remote biometric identification and categorisation systems based on sensitive attributes are classified as high-risk, requiring additional compliance obligations.</dd>
              </div>
            </dl>
          </div>
        </div>
      </section>

      <!-- How it works (brief) -->
      <!-- Use Case 1: LLM Inference -->
      <section class="usecase-section">
        <h2>LLM inference without PII exposure</h2>
        <p class="usecase-desc">Send data to any third-party LLM safely. PII is replaced with indexed tokens before leaving your infrastructure, and restored in the final output.</p>

        <div class="usecase-flow">
          <div class="flow-cols">
            <div class="flow-col">
              <div class="flow-col-label">Your infrastructure</div>
            </div>
            <div class="flow-col flow-col-ext">
              <div class="flow-col-label flow-col-label-ext">Third-party LLM</div>
            </div>
          </div>

          <div class="flow-cols">
            <div class="flow-col">
              <div class="flow-step">
                <div class="step-marker">1</div>
                <div class="step-content">
                  <div class="step-title">Original prompt</div>
                  <code class="step-code">Wyciągnij dane z faktury: wystawiona dla <span class="hl">Jan Kowalski</span>, NIP <span class="hl">527-020-1234</span>, adres <span class="hl">ul. Marszałkowska 10/5, 00-001 Warszawa</span>, konto <span class="hl">PL61 1090 1014 0000 0712 1981 2874</span>, kwota <span class="hl">12 500 PLN</span></code>
                </div>
              </div>

              <div class="flow-arrow">↓ <span>Anonymize</span></div>

              <div class="flow-step">
                <div class="step-marker">2</div>
                <div class="step-content">
                  <div class="step-title">Anonymized prompt</div>
                  <code class="step-code">Wyciągnij dane z faktury: wystawiona dla <span class="hl-token">[PERSON_NAME_1]</span>, NIP <span class="hl-token">[ORGANIZATION_IDENTIFIER_1]</span>, adres <span class="hl-token">[POSTAL_ADDRESS_1]</span>, konto <span class="hl-token">[BANK_ACCOUNT_IDENTIFIER_1]</span>, kwota <span class="hl-token">[FINANCIAL_AMOUNT_1]</span></code>
                </div>
              </div>
            </div>
            <div class="flow-col flow-col-ext">
              <div class="flow-transfer">→</div>
            </div>
          </div>

          <!-- Mobile: send to LLM arrow -->
          <div class="flow-arrow mobile-only">→ <span>Send to third-party LLM</span></div>

          <div class="flow-cols">
            <div class="flow-col">
              <div class="flow-transfer flow-transfer-in">←</div>
            </div>
            <div class="flow-col flow-col-ext">
              <div class="flow-step">
                <div class="step-marker">3</div>
                <div class="step-content">
                  <div class="step-title">LLM response <span class="ext-badge">external</span></div>
                  <code class="step-code step-code-mono">{"{"}<br/>&nbsp;&nbsp;"vendor": "<span class="hl-token">[PERSON_NAME_1]</span>",<br/>&nbsp;&nbsp;"tax_id": "<span class="hl-token">[ORGANIZATION_IDENTIFIER_1]</span>",<br/>&nbsp;&nbsp;"address": "<span class="hl-token">[POSTAL_ADDRESS_1]</span>",<br/>&nbsp;&nbsp;"iban": "<span class="hl-token">[BANK_ACCOUNT_IDENTIFIER_1]</span>",<br/>&nbsp;&nbsp;"amount": "<span class="hl-token">[FINANCIAL_AMOUNT_1]</span>"<br/>{"}"}</code>
                </div>
              </div>
            </div>
          </div>

          <!-- Mobile: return arrow -->
          <div class="flow-arrow mobile-only">← <span>Response returns to your infrastructure</span></div>

          <div class="flow-cols">
            <div class="flow-col">
              <div class="flow-arrow">↓ <span>De-anonymize</span></div>

              <div class="flow-step">
                <div class="step-marker">4</div>
                <div class="step-content">
                  <div class="step-title">Final result</div>
                  <code class="step-code step-code-mono">{"{"}<br/>&nbsp;&nbsp;"vendor": "<span class="hl">Jan Kowalski</span>",<br/>&nbsp;&nbsp;"tax_id": "<span class="hl">527-020-1234</span>",<br/>&nbsp;&nbsp;"address": "<span class="hl">ul. Marszałkowska 10/5, ...</span>",<br/>&nbsp;&nbsp;"iban": "<span class="hl">PL61 1090 ... 2874</span>",<br/>&nbsp;&nbsp;"amount": "<span class="hl">12 500 PLN</span>"<br/>{"}"}</code>
                </div>
              </div>
            </div>
            <div class="flow-col flow-col-ext"></div>
          </div>
        </div>

        <div class="usecase-mapping">
          <div class="mapping-label">Entity mapping (stored locally, never sent)</div>
          <div class="mapping-table">
            <code class="hl-token">[PERSON_NAME_1]</code><span class="mapping-sep">↔</span><code>Jan Kowalski</code>
            <code class="hl-token">[ORGANIZATION_IDENTIFIER_1]</code><span class="mapping-sep">↔</span><code>527-020-1234</code>
            <code class="hl-token">[POSTAL_ADDRESS_1]</code><span class="mapping-sep">↔</span><code>ul. Marszałkowska 10/5, ...</code>
            <code class="hl-token">[BANK_ACCOUNT_IDENTIFIER_1]</code><span class="mapping-sep">↔</span><code>PL61 1090 ... 2874</code>
            <code class="hl-token">[FINANCIAL_AMOUNT_1]</code><span class="mapping-sep">↔</span><code>12 500 PLN</code>
          </div>
        </div>
      </section>

      <!-- Use Case 2: Training Data -->
      <section class="usecase-section">
        <h2>GDPR-safe model training data</h2>
        <p class="usecase-desc">Prepare datasets that comply with EU AI Act Art.&nbsp;10(5). Real PII is replaced with synthetic data — the text structure stays intact for learning, but contains zero real personal information.</p>

        <div class="usecase-flow">
          <div class="flow-step">
            <div class="step-marker">1</div>
            <div class="step-content">
              <div class="step-title">Original training record</div>
              <code class="step-code">Pacjent <span class="hl">Emil Nowak</span> (PESEL: <span class="hl">91082734567</span>), zam. <span class="hl">ul. Lipowa 22, 30-702 Kraków</span>, zgłosił się z <span class="hl-special">bólem w klatce piersiowej</span>. Lekarz prowadzący: <span class="hl">dr Anna Wiśniewska</span>.</code>
            </div>
          </div>

          <div class="flow-arrow">↓ <span>Detect &amp; replace with synthetic data</span></div>

          <div class="flow-step">
            <div class="step-marker">2</div>
            <div class="step-content">
              <div class="step-title">Anonymized training record</div>
              <code class="step-code">Pacjent <span class="hl-synth">Tomasz Zieliński</span> (PESEL: <span class="hl-synth">85120498321</span>), zam. <span class="hl-synth">ul. Dębowa 7, 50-307 Wrocław</span>, zgłosił się z <span class="hl-synth">bólem głowy</span>. Lekarz prowadzący: <span class="hl-synth">dr Katarzyna Lewandowska</span>.</code>
            </div>
          </div>

          <div class="flow-arrow">↓ <span>Safe for training</span></div>

          <div class="flow-step flow-step-result">
            <div class="step-marker">3</div>
            <div class="step-content">
              <div class="step-title">Model training</div>
              <code class="step-code">Text structure preserved. No real person identifiable. Compliant with GDPR Art.&nbsp;89 and EU&nbsp;AI&nbsp;Act Art.&nbsp;10(5).</code>
            </div>
          </div>
        </div>

        <div class="usecase-mapping">
          <div class="mapping-label">Each record gets unique synthetic replacements</div>
          <div class="mapping-table">
            <code><span class="hl">Emil Nowak</span></code><span class="mapping-sep">→</span><code><span class="hl-synth">Tomasz Zieliński</span></code>
            <code><span class="hl">91082734567</span></code><span class="mapping-sep">→</span><code><span class="hl-synth">85120498321</span></code>
            <code><span class="hl">ul. Lipowa 22, ...</span></code><span class="mapping-sep">→</span><code><span class="hl-synth">ul. Dębowa 7, ...</span></code>
            <code><span class="hl-special">ból w klatce piersiowej</span></code><span class="mapping-sep">→</span><code><span class="hl-synth">ból głowy</span></code>
            <code><span class="hl">dr Anna Wiśniewska</span></code><span class="mapping-sep">→</span><code><span class="hl-synth">dr K. Lewandowska</span></code>
          </div>
        </div>
      </section>

      <!-- Quick Links -->
      <section class="links-section">
        <a href="/docs" class="link-card card">
          <strong>Documentation</strong>
          <span>Entity reference, model card, integration guide</span>
        </a>
        <a href="/docs/model-card" class="link-card card">
          <strong>Model card</strong>
          <span>Architecture, ~95% F1, limitations</span>
        </a>
        <a href="https://huggingface.co/bardsai/eu-pii-anonimization" target="_blank" rel="noopener" class="link-card card">
          <strong>HuggingFace</strong>
          <span>Download model, weights, tokenizer</span>
        </a>
      </section>

      <!-- Legend -->
      <section class="legend">
        <div class="legend-grid">
          <span class="legend-item"><span class="dot dot-standard"></span> Standard PII &mdash; Art. 4(1)</span>
          <span class="legend-item"><span class="dot dot-special"></span> Special category &mdash; Art. 9(1)</span>
        </div>
      </section>
    </main>
    <Footer />

    <script>
      import { SentenceSplitterSyntax, split } from "sentence-splitter";

      const SAMPLES: Record<string, string> = {
        "1": `Pracownik Anna Wiśniewska, zatrudniona w dziale IT, otrzymuje wynagrodzenie w wysokości 12 500 PLN brutto. Numer paszportu: EP1234567. NIP firmy: 527-020-1234. Adres zamieszkania: ul. Piękna 22, 00-549 Warszawa. Wyznanie: katolicyzm. Przynależność związkowa: NSZZ.`,
        "2": `Nazywam się Jan Kowalski, urodzony 15 marca 1985 roku w Warszawie. Mój numer PESEL to 85031512345, a numer dowodu osobistego ABC123456. Mieszkam przy ul. Marszałkowskiej 10/5, 00-001 Warszawa. Mój adres e-mail to jan.kowalski@example.com, a numer telefonu +48 600 123 456.`,
        "3": `Pacjent Adam Nowak (PESEL: 90010112345) zgłosił się do kliniki z rozpoznaniem cukrzycy typu 2. Numer ubezpieczenia zdrowotnego: NFZ-WA-123456789. Rachunek bankowy do zwrotu kosztów: PL61 1090 1014 0000 0712 1981 2874. Adres IP urządzenia pacjenta: 192.168.1.105.`,
      };

      const REGULATION_MAP: Record<string, string> = {
        "cat-identity": "Art. 4(1)",
        "cat-contact": "Art. 4(1)",
        "cat-technical": "Recital 30",
        "cat-financial": "Art. 4(1)",
        "cat-health": "Art. 9(1)",
        "cat-special": "Art. 9(1)",
        "cat-employment": "Art. 88",
      };

      const CATEGORY_MAP: Record<string, string> = {
        PERSON_NAME: "cat-identity",
        DATE_OF_BIRTH: "cat-identity",
        PERSON_ATTRIBUTE: "cat-identity",
        PERSON_ALIAS: "cat-identity",
        PERSON_IDENTIFIER: "cat-identity",
        PERSON_ROLE_OR_TITLE: "cat-employment",
        ORGANIZATION_NAME: "cat-identity",
        ORGANIZATION_IDENTIFIER: "cat-identity",
        EMAIL_ADDRESS: "cat-contact",
        PHONE_NUMBER: "cat-contact",
        CONTACT_HANDLE: "cat-contact",
        POSTAL_ADDRESS: "cat-contact",
        LOCATION: "cat-contact",
        GEO_LOCATION: "cat-contact",
        IP_ADDRESS: "cat-technical",
        DEVICE_IDENTIFIER: "cat-technical",
        COOKIE_IDENTIFIER: "cat-technical",
        ACCOUNT_IDENTIFIER: "cat-technical",
        AUTH_SECRET: "cat-technical",
        BANK_ACCOUNT_IDENTIFIER: "cat-financial",
        PAYMENT_CARD: "cat-financial",
        PAYMENT_CARD_SECURITY: "cat-financial",
        DOCUMENT_REFERENCE: "cat-financial",
        FINANCIAL_AMOUNT: "cat-financial",
        INCOME_COMPENSATION: "cat-financial",
        VEHICLE_IDENTIFIER: "cat-financial",
        HEALTH_DATA: "cat-health",
        GENETIC_DATA: "cat-health",
        BIOMETRIC_DATA: "cat-health",
        RELIGION_OR_BELIEF: "cat-special",
        POLITICAL_OPINION: "cat-special",
        SEXUAL_ORIENTATION: "cat-special",
        TRADE_UNION_MEMBERSHIP: "cat-special",
        ETHNIC_ORIGIN: "cat-special",
        CRIMINAL_OFFENCE_DATA: "cat-special",
      };

      const MAX_WORDS_PER_CHUNK = 200;

      interface TextChunk {
        text: string;
        start: number;
        end: number;
        wordCount: number;
      }

      function countWords(value: string): number {
        const matches = value.trim().match(/\S+/gu);
        return matches ? matches.length : 0;
      }

      function splitRangeIntoWordChunks(text: string, start: number, end: number, maxWords: number): TextChunk[] {
        const rangeText = text.slice(start, end);
        const wordMatches = Array.from(rangeText.matchAll(/\S+/gu));

        if (wordMatches.length === 0) {
          return rangeText.trim()
            ? [{ text: rangeText, start, end, wordCount: countWords(rangeText) }]
            : [];
        }

        const chunks: TextChunk[] = [];

        for (let wordIndex = 0; wordIndex < wordMatches.length; wordIndex += maxWords) {
          const nextWordIndex = Math.min(wordIndex + maxWords, wordMatches.length);
          const chunkStartLocal = wordIndex === 0 ? 0 : (wordMatches[wordIndex].index ?? 0);
          const chunkEndLocal = nextWordIndex < wordMatches.length
            ? (wordMatches[nextWordIndex].index ?? rangeText.length)
            : rangeText.length;

          chunks.push({
            text: rangeText.slice(chunkStartLocal, chunkEndLocal),
            start: start + chunkStartLocal,
            end: start + chunkEndLocal,
            wordCount: nextWordIndex - wordIndex,
          });
        }

        return chunks;
      }

      function chunkTextBySentence(text: string, maxWords = MAX_WORDS_PER_CHUNK): TextChunk[] {
        const nodes = split(text);
        const sentenceNodes = nodes.filter(
          (node): node is { type: "Sentence"; raw: string; range: [number, number] } =>
            node.type === SentenceSplitterSyntax.Sentence && Array.isArray(node.range)
        );

        if (sentenceNodes.length === 0) {
          return splitRangeIntoWordChunks(text, 0, text.length, maxWords);
        }

        const chunks: TextChunk[] = [];
        let currentStart = -1;
        let currentEnd = -1;
        let currentWords = 0;

        const flushCurrent = () => {
          if (currentStart < 0 || currentEnd <= currentStart) return;

          chunks.push({
            text: text.slice(currentStart, currentEnd),
            start: currentStart,
            end: currentEnd,
            wordCount: currentWords,
          });

          currentStart = -1;
          currentEnd = -1;
          currentWords = 0;
        };

        for (const sentence of sentenceNodes) {
          const [sentenceStart, sentenceEnd] = sentence.range;
          const sentenceWordCount = countWords(sentence.raw);

          if (sentenceWordCount === 0) continue;

          if (sentenceWordCount > maxWords) {
            flushCurrent();
            chunks.push(...splitRangeIntoWordChunks(text, sentenceStart, sentenceEnd, maxWords));
            continue;
          }

          if (currentStart < 0) {
            currentStart = sentenceStart;
            currentEnd = sentenceEnd;
            currentWords = sentenceWordCount;
            continue;
          }

          if (currentWords + sentenceWordCount > maxWords) {
            flushCurrent();
            currentStart = sentenceStart;
            currentEnd = sentenceEnd;
            currentWords = sentenceWordCount;
            continue;
          }

          currentEnd = sentenceEnd;
          currentWords += sentenceWordCount;
        }

        flushCurrent();

        return chunks.length > 0 ? chunks : splitRangeIntoWordChunks(text, 0, text.length, maxWords);
      }

      // Show mobile warning
      const isMobile = /Android|iPhone|iPad|iPod/i.test(navigator.userAgent) || window.innerWidth < 768;
      if (isMobile) {
        const mobileWarning = document.getElementById("mobile-warning");
        if (mobileWarning) mobileWarning.style.display = "block";
      }

      const loadBtn = document.getElementById("load-btn") as HTMLButtonElement;
      const analyzeBtn = document.getElementById("analyze-btn") as HTMLButtonElement;
      const inputText = document.getElementById("input-text") as HTMLTextAreaElement;
      const outputAnonymized = document.getElementById("output-anonymized") as HTMLDivElement;
      const outputHighlighted = document.getElementById("output-highlighted") as HTMLDivElement;
      const statusText = document.getElementById("status-text") as HTMLDivElement;
      const progressContainer = document.getElementById("progress-container") as HTMLDivElement;
      const progressBar = document.getElementById("progress-bar") as HTMLDivElement;
      const entityList = document.getElementById("entity-list") as HTMLDivElement;
      const entityTableContainer = document.getElementById("entity-table-container") as HTMLDivElement;
      const viewToggle = document.getElementById("view-toggle") as HTMLDivElement;
      const previewLabel = document.getElementById("preview-label") as HTMLSpanElement;

      let modelLoaded = false;
      let worker: Worker | null = null;

      // View toggle logic
      document.querySelectorAll(".toggle-btn").forEach((btn) => {
        btn.addEventListener("click", () => {
          document.querySelectorAll(".toggle-btn").forEach((b) => b.classList.remove("active"));
          btn.classList.add("active");
          const view = (btn as HTMLElement).dataset.view;
          if (view === "anonymized") {
            outputAnonymized.style.display = "block";
            outputHighlighted.style.display = "none";
          } else {
            outputAnonymized.style.display = "none";
            outputHighlighted.style.display = "block";
          }
        });
      });

      function createWorker() {
        const w = new Worker("/worker.js", { type: "module" });

        w.onmessage = (e) => {
          const { type } = e.data;

          if (type === "status") {
            statusText.textContent = e.data.message;
          } else if (type === "progress") {
            const p = e.data.data;
            if (p.status === "progress" && p.progress != null) {
              progressContainer.style.display = "block";
              const pct = Math.round(p.progress);
              progressBar.style.width = `${pct}%`;
              statusText.textContent = `Downloading ${p.file || "model"}: ${pct}%`;
            } else if (p.status === "done") {
              progressBar.style.width = "100%";
            } else if (p.status === "ready") {
              progressContainer.style.display = "none";
            }
          } else if (type === "loaded") {
            modelLoaded = true;
            statusText.textContent = "Model loaded and ready!";
            statusText.classList.add("ready");
            progressContainer.style.display = "none";
            loadBtn.disabled = true;
            loadBtn.textContent = "Model ready";
            analyzeBtn.disabled = false;
          } else if (type === "result") {
            const normalized = normalizeEntities(e.data.data, inputText.value);
            const merged = mergeAdjacentEntities(normalized, inputText.value);
            renderResults(merged);
            analyzeBtn.disabled = false;
            analyzeBtn.textContent = "Analyze";
            const chunkCount = e.data.meta?.chunkCount ?? 1;
            statusText.textContent = chunkCount > 1
              ? `Analyzed ${chunkCount} chunks. Model loaded and ready!`
              : "Model loaded and ready!";

            // On mobile, terminate worker after inference to free ~300MB WASM memory.
            // Model files are cached in Cache API so re-loading is fast (no re-download).
            if (isMobile) {
              w.terminate();
              worker = null;
              modelLoaded = false;
              loadBtn.disabled = false;
              loadBtn.textContent = "Load model for another analysis";
              statusText.textContent = "Model unloaded to free memory.";
              statusText.classList.remove("ready");
              analyzeBtn.disabled = true;
            }
          } else if (type === "error") {
            statusText.textContent = `Error: ${e.data.message}`;
            statusText.classList.add("error");
            analyzeBtn.disabled = false;
            analyzeBtn.textContent = "Analyze";
          }
        };

        return w;
      }

      worker = createWorker();

      loadBtn.addEventListener("click", () => {
        // Re-create worker if it was terminated (mobile memory management)
        if (!worker) {
          worker = createWorker();
        }
        loadBtn.disabled = true;
        loadBtn.textContent = "Downloading...";
        statusText.classList.remove("error");
        worker.postMessage({ type: "load" });
      });

      analyzeBtn.addEventListener("click", () => {
        const text = inputText.value.trim();
        if (!text || !worker) return;
        const chunks = chunkTextBySentence(text);
        analyzeBtn.disabled = true;
        analyzeBtn.textContent = "Analyzing...";
        outputAnonymized.innerHTML = '<span class="placeholder-text">Processing...</span>';
        outputHighlighted.innerHTML = "";
        entityList.style.display = "none";
        statusText.textContent = chunks.length > 1
          ? `Prepared ${chunks.length} chunks for analysis...`
          : "Analyzing text...";
        worker.postMessage({ type: "classify", text, chunks });
      });

      document.querySelectorAll(".sample-btn").forEach((btn) => {
        btn.addEventListener("click", () => {
          const sample = (btn as HTMLElement).dataset.sample!;
          inputText.value = SAMPLES[sample];
        });
      });

      interface Entity {
        entity_group: string;
        word: string;
        score: number;
        start: number;
        end: number;
      }

      function getCategoryClass(entityGroup: string): string {
        return CATEGORY_MAP[entityGroup] || "cat-identity";
      }

      function normalizeEntities(raw: any[], text: string): Entity[] {
        if (!raw || raw.length === 0) return [];

        const entities: Entity[] = [];
        let current: Entity | null = null;

        for (const token of raw) {
          const rawLabel = token.entity_group || token.entity || "";
          const score = token.score || 0;
          const start = token.start;
          const end = token.end;

          let tag = "O";
          let entityType = "";
          if (rawLabel.startsWith("B-")) {
            tag = "B";
            entityType = rawLabel.slice(2);
          } else if (rawLabel.startsWith("I-")) {
            tag = "I";
            entityType = rawLabel.slice(2);
          } else if (rawLabel !== "O" && rawLabel !== "LABEL_0" && rawLabel !== "") {
            tag = "B";
            entityType = rawLabel;
          }

          if (tag === "B") {
            if (current) entities.push(current);
            current = {
              entity_group: entityType,
              word: text.slice(start, end),
              score,
              start,
              end,
            };
          } else if (tag === "I" && current && current.entity_group === entityType) {
            current.end = end;
            current.word = text.slice(current.start, end);
            current.score = Math.max(current.score, score);
          } else {
            if (current) {
              entities.push(current);
              current = null;
            }
          }
        }
        if (current) entities.push(current);

        return entities;
      }

      function mergeAdjacentEntities(entities: Entity[], text: string): Entity[] {
        if (entities.length <= 1) return entities;
        const sorted = [...entities].sort((a, b) => a.start - b.start);
        const merged: Entity[] = [sorted[0]];

        for (let i = 1; i < sorted.length; i++) {
          const prev = merged[merged.length - 1];
          const curr = sorted[i];

          const gap = text.slice(prev.end, curr.start);
          const overlapping = curr.start <= prev.end;
          const punctuationBridge = gap.length > 0 && gap.length <= 3 && /^[.,;:\-/]+$/.test(gap);
          if (prev.entity_group === curr.entity_group && (overlapping || punctuationBridge)) {
            prev.end = curr.end;
            prev.word = text.slice(prev.start, prev.end);
            prev.score = Math.max(prev.score, curr.score);
          } else {
            merged.push(curr);
          }
        }

        return merged;
      }

      function renderResults(entities: Entity[]) {
        if (previewLabel) previewLabel.style.display = "none";
        const text = inputText.value;

        if (!entities || entities.length === 0) {
          outputAnonymized.innerHTML = `<span class="no-entities">No PII entities detected.</span><br><br>${escapeHtml(text)}`;
          outputHighlighted.innerHTML = escapeHtml(text);
          entityList.style.display = "none";
          viewToggle.style.display = "none";
          return;
        }

        const valid = entities.filter(
          (e) => typeof e.start === "number" && typeof e.end === "number" && e.entity_group
        );

        if (valid.length === 0) {
          outputAnonymized.innerHTML = `<span class="no-entities">No valid PII entities detected.</span><br><br>${escapeHtml(text)}`;
          outputHighlighted.innerHTML = escapeHtml(text);
          entityList.style.display = "none";
          viewToggle.style.display = "none";
          return;
        }

        const sorted = [...valid].sort((a, b) => a.start - b.start);

        let anonHtml = "";
        let highlightHtml = "";
        let lastEnd = 0;

        for (const entity of sorted) {
          if (entity.start < lastEnd) continue;

          const cat = getCategoryClass(entity.entity_group);
          const score = Math.round(entity.score * 100);
          const beforeText = escapeHtml(text.slice(lastEnd, entity.start));

          anonHtml += beforeText;
          anonHtml += `<span class="anon-tag ${cat}" title="Was: ${escapeHtml(text.slice(entity.start, entity.end))} (${score}%)">[${entity.entity_group}]</span>`;

          highlightHtml += beforeText;
          highlightHtml += `<mark class="entity ${cat}" title="${entity.entity_group} (${score}%)">${escapeHtml(text.slice(entity.start, entity.end))}<span class="entity-label">${entity.entity_group}</span></mark>`;

          lastEnd = entity.end;
        }

        const trailingText = escapeHtml(text.slice(lastEnd));
        anonHtml += trailingText;
        highlightHtml += trailingText;

        outputAnonymized.innerHTML = anonHtml;
        outputHighlighted.innerHTML = highlightHtml;
        viewToggle.style.display = "flex";

        entityList.style.display = "block";
        let tableHtml = `<table class="results-table"><thead><tr><th>Entity</th><th>Type</th><th>Regulation</th><th class="col-confidence">Confidence</th></tr></thead><tbody>`;
        for (const entity of sorted) {
          if (entity.start < 0) continue;
          const cat = getCategoryClass(entity.entity_group);
          const score = Math.round(entity.score * 100);
          const originalText = text.slice(entity.start, entity.end);
          const reg = REGULATION_MAP[cat] || "Art. 4(1)";
          const isSpecial = cat === "cat-health" || cat === "cat-special";
          const regLabel = isSpecial
            ? `<span class="reg-ref reg-special">${reg}</span>`
            : `<span class="reg-ref">${reg}</span>`;
          tableHtml += `<tr><td><span class="entity-badge ${cat}">${escapeHtml(originalText)}</span></td><td><code>${entity.entity_group}</code></td><td>${regLabel}</td><td class="col-confidence">${score}%</td></tr>`;
        }
        tableHtml += `</tbody></table>`;
        entityTableContainer.innerHTML = tableHtml;
      }

      function escapeHtml(str: string): string {
        const div = document.createElement("div");
        div.textContent = str;
        return div.innerHTML;
      }
    </script>
  </body>
</html>

